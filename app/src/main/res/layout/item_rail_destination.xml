<?xml version="1.0" encoding="utf-8"?>
<!--
  Single rail destination row.

  Visual spec:
    - 72dp wide column matching the rail's collapsed width.
    - Icon (24dp) + LabelMedium below it (rail M3 spec).
    - 56dp tall touch target.
    - Selected state painted by `rail_item_indicator` drawable (no green
      pill — neutral colorSurfaceContainerHigh) plus tint flip on icon
      and label.
    - Outer LinearLayout is the click target. The rail driver tags it
      with the destination id.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="32dp"
        android:background="@drawable/rail_item_indicator">

        <ImageView
            android:id="@+id/railItemIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:duplicateParentState="true"
            app:tint="@color/rail_item_icon_tint" />
    </FrameLayout>

    <TextView
        android:id="@+id/railItemLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:duplicateParentState="true"
        android:gravity="center_horizontal"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textColor="@color/rail_item_label_tint" />
</LinearLayout>
