<?xml version="1.0" encoding="utf-8"?>
<!--
  Rail icon color: bold colorOnSurface when selected, dimmer
  colorOnSurfaceVariant otherwise. No primary/secondary — keeps the
  rail tonally neutral.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true" android:color="?attr/colorOnSurface" />
    <item android:color="?attr/colorOnSurfaceVariant" />
</selector>
